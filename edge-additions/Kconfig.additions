# Kconfig.additions — paste these into Edge's main/Kconfig.projbuild
# (or any Kconfig file under "menu \"Narbis Earclip\"" if you prefer).
#
# Symbol names match the earclip's own Kconfig so you can reuse the same
# operational tooling. Do not rename them.

config NARBIS_HARDCODED_PARTNER_MAC
    bool "Use hardcoded ESP-NOW partner (earclip) MAC as fallback"
    default y
    help
        When the Edge runtime config has not yet been populated (no MAC in
        NVS namespace "narbis_pair", key "partner_mac"), fall back to the
        MAC compiled in via NARBIS_HARDCODED_PARTNER_MAC_VAL.

config NARBIS_HARDCODED_PARTNER_MAC_VAL
    string "Hardcoded earclip MAC (colon-separated, six octets)"
    depends on NARBIS_HARDCODED_PARTNER_MAC
    default "FF:FF:FF:FF:FF:FF"
    help
        Six-byte MAC, colon-separated, used when no partner MAC is stored
        in NVS. The default broadcast address makes unconfigured Edge
        units inert until paired (no peer added, all frames dropped as
        wrong-peer).

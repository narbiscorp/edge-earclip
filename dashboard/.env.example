# Supabase project URL and anon (public) key.
#
# - Copy this file to `.env.local` and fill the two values from your Supabase
#   project's "Project Settings → API" page.
# - `.env.local` is gitignored. Never commit real values.
# - In CI (GitHub Actions), these are injected from repository secrets at
#   build time — see `.github/workflows/dashboard-deploy.yml`.
# - The anon key is safe to ship to the browser; database security is
#   enforced by Postgres row-level security policies on each table.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

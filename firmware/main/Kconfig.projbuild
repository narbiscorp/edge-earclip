menu "Narbis earclip"

    config NARBIS_HARDCODED_PARTNER_MAC
        bool "Use hardcoded ESP-NOW partner MAC as fallback"
        default y
        help
            When the runtime config has not yet been populated (partner_mac is
            all zero in NVS), fall back to the MAC compiled in via
            NARBIS_HARDCODED_PARTNER_MAC_VAL. Disable this in production builds
            where every device must be paired via the dashboard before use.

    config NARBIS_HARDCODED_PARTNER_MAC_VAL
        string "Hardcoded ESP-NOW partner MAC"
        depends on NARBIS_HARDCODED_PARTNER_MAC
        default "FF:FF:FF:FF:FF:FF"
        help
            Six-byte MAC, colon-separated, used when no partner MAC is stored
            in NVS. The default broadcast address is intentional — it makes
            unconfigured units inert until paired.

    config NARBIS_ESPNOW_CHANNEL
        int "ESP-NOW Wi-Fi channel"
        range 1 13
        default 1
        help
            Wi-Fi channel used for ESP-NOW frames. The earclip sets this on the
            radio at boot and on each peer entry. Must match the receiver's
            channel. Stage 07 will override this at runtime from
            narbis_runtime_config_t.espnow_channel.

    config NARBIS_TEST_INJECT
        bool "Use synthetic 1 Hz PPG injector instead of real driver"
        default n
        help
            Replaces the MAX3010x driver with a built-in 1 Hz sine generator
            for end-to-end DSP smoke testing without hardware. Expected
            output is a beat event every ~1000 ms with confidence near 100
            and no ARTIFACT flag once the running median has filled.

    config NARBIS_BATT_DIVIDER_PRESENT
        bool "Battery voltage divider populated on the XIAO C6"
        default n
        help
            Set to y after soldering a 1 MΩ : 1 MΩ resistor divider from
            BAT+ → A1 (GPIO1) → GND on the XIAO ESP32-C6. While n
            (default), power_mgmt_get_battery() returns placeholder
            values (4000 mV / 80%) with a rate-limited STUB warning so
            the ESP-NOW + BLE battery frames stay meaningful for
            transport testing. See TODO.md and CLAUDE.md hardware section.

    config NARBIS_BATT_ADC_GPIO
        int "Battery sense ADC GPIO"
        depends on NARBIS_BATT_DIVIDER_PRESENT
        range 0 6
        default 1
        help
            GPIO number wired to the battery voltage divider midpoint.
            Must be ADC-capable on the ESP32-C6 (GPIO0..GPIO6 = ADC1).
            Default: GPIO1 (D1 / A1).

    config NARBIS_BATT_ADC_DIV_NUM
        int "Battery divider numerator"
        depends on NARBIS_BATT_DIVIDER_PRESENT
        range 1 16
        default 2
        help
            Divider ratio numerator. With a 1:1 divider (BAT+ → 1 MΩ →
            A1 → 1 MΩ → GND), the pin sees half of BAT+, so the firmware
            multiplies the ADC voltage by 2/1 = NUM/DEN.

    config NARBIS_BATT_ADC_DIV_DEN
        int "Battery divider denominator"
        depends on NARBIS_BATT_DIVIDER_PRESENT
        range 1 16
        default 1
        help
            Divider ratio denominator. See NARBIS_BATT_ADC_DIV_NUM.

    menu "OTA"

        config NARBIS_OTA_VALIDITY_TIMEOUT_S
            int "First-connect timeout for OTA validity self-test (s)"
            range 5 600
            default 60
            help
                On boot from a freshly-OTA'd partition (state =
                ESP_OTA_IMG_PENDING_VERIFY), the firmware waits up to
                this many seconds for a BLE central to connect before
                marking the image valid. If no connection happens, the
                bootloader rolls back to the previous slot on the next
                reset. 60 s mirrors the staged-prompt requirement.

    endmenu

endmenu
